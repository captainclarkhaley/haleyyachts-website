# ============================================================
# Haley Yachts Admin - Password Protection
# ============================================================
# This file restricts access to everything inside /admin/.
# Visitors will be prompted for a username and password before
# they can see any admin tool.
#
# SETUP (do this once, on the GoDaddy server):
#   1. In cPanel, go to "Directory Privacy" (or "Password
#      Protect Directories").
#   2. Browse to the /admin/ folder on public_html.
#   3. Check "Password protect this directory" and give it a
#      name like "Haley Yachts Admin".
#   4. Add a user (e.g., clark) and set a strong password.
#      cPanel will automatically generate the .htpasswd file.
#
# The cp:ppd block at the bottom of this file is managed by
# cPanel's Directory Privacy tool and should not be hand-edited.
# If you re-run Directory Privacy, cPanel will regenerate it.
# ============================================================

# ----- Deny direct access to sensitive files -----
<FilesMatch "^\.(htaccess|htpasswd)$">
    Require all denied
</FilesMatch>

<Files "config.yml">
    Require all denied
</Files>

# ----- No directory listing -----
Options -Indexes

#----------------------------------------------------------------cp:ppd
# Section managed by cPanel: Password Protected Directories     -cp:ppd
# - Do not edit this section of the htaccess file!              -cp:ppd
#----------------------------------------------------------------cp:ppd
AuthType Basic
AuthName "Haley Yachts Admin"
AuthUserFile "/home/gze7mqui4ce6/.htpasswds/public_html/admin/passwd"
Require valid-user
#----------------------------------------------------------------cp:ppd
# End section managed by cPanel: Password Protected Directories -cp:ppd
#----------------------------------------------------------------cp:ppd
