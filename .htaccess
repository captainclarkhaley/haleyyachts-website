# ============================================================
# Haley Yachts - Root Apache config
# ============================================================
# Controls HTTPS enforcement, security headers, URL rewriting,
# and hardening for /public_html/.
#
# This file lives in the git repo. All edits deploy via
# GitHub -> cPanel Git Version Control Pull. Do not hand-edit
# the live copy on GoDaddy; drift causes pull conflicts.
# ============================================================


# ----- 1. Force HTTPS ------------------------------------------------
# Any http:// request gets 301-redirected to https://, same host,
# same path. Must come before HSTS so we never send the HSTS header
# over an insecure response.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>


# ----- 2. Security headers -------------------------------------------
<IfModule mod_headers.c>
    # 1-year HSTS. Browsers remember this for max-age, so rolling
    # back is painful. Safe now that HTTPS is forced above.
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Stop browsers from MIME-sniffing responses.
    Header always set X-Content-Type-Options "nosniff"

    # Disallow framing by other origins (anti-clickjacking).
    Header always set X-Frame-Options "SAMEORIGIN"

    # Trim referrer info leaked to cross-origin sites.
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Disable browser APIs this site does not use.
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

    # Content-Security-Policy intentionally omitted for now.
    # The homepage includes a GoDaddy inline tracking snippet, which
    # makes a strict CSP disruptive. Revisit when we are ready to
    # either self-host that snippet or add per-response nonces.
</IfModule>


# ----- 3. Extensionless URL routing ----------------------------------
# Let /contact, /buy, /articles/boat-reviews/<slug> work without
# the visitor having to type .html. Internal rewrite only, so
# links with or without .html both keep working.
<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the path is a real file or directory, leave it alone.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Otherwise, if <path>.html exists in the docroot, serve it.
    RewriteCond %{DOCUMENT_ROOT}/$1.html -f
    RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>


# ----- 3b. Legacy brochure paths --------------------------------------
# 2026-07-21: yacht brochures moved from /documents/yachts/featured/ to
# /documents/yachts/, one canonical document per boat. The old folder
# name implied the Featured Yacht tool owned the file's lifecycle, but a
# spec sheet is linked by the Logbook long after the boat leaves the
# featured rotation.
#
# These 301s exist so the already-published Logbook issues and their web
# archives keep working. Those pages are dated records and are NOT edited
# to point at the new paths - the redirect carries them instead. Do not
# remove these; the emails are already in people's inboxes and cannot be
# revised.
#
# The two 1991 Southern Wind lines both land on the current Fortunato
# brochure: the May issue linked an earlier revision of the same document,
# and a visitor clicking a spec sheet should get the accurate one. The
# superseded revisions are kept, unlinked, in documents/yachts/archive/.
<IfModule mod_alias.c>
    RedirectPermanent /documents/yachts/featured/1991-Southern_Wind-Bruce_Farr_Fast_72.pdf   /documents/yachts/1991-southern-wind-72-fortunato.pdf
    RedirectPermanent /documents/yachts/featured/1991-southern-wind-bruce-farr-fast-72.pdf   /documents/yachts/1991-southern-wind-72-fortunato.pdf
    RedirectPermanent /documents/yachts/featured/2020-Riviera-545_SUV.pdf                    /documents/yachts/2020-riviera-545-suv-fringe-benefits.pdf
    RedirectPermanent /documents/yachts/featured/2023-Riviera-64_Sports_Motor_Yacht.pdf      /documents/yachts/2023-riviera-64-sports-motor-yacht.pdf
    RedirectPermanent /documents/yachts/featured/2024-Sunseeker-Manhattan_68.pdf             /documents/yachts/2024-sunseeker-manhattan-68.pdf
    RedirectPermanent /documents/yachts/featured/2024-Sunseeker-Superhawk_55.pdf             /documents/yachts/2024-sunseeker-superhawk-55.pdf
    RedirectPermanent /documents/yachts/featured/2024-riviera-465-suv.pdf                    /documents/yachts/2024-riviera-465-suv.pdf
    RedirectPermanent /documents/yachts/featured/2026-HCB-56_SUENOS_GIX.pdf                  /documents/yachts/2026-hcb-56-suenos-gix.pdf

    # Sangaris sold and left the featured rotation, and the old delete path took
    # her brochure with it (commit 3e968ce, 2026-06-08) - which broke the spec-sheet
    # link in the already-sent May 2026 Logbook. The file is recovered from git
    # history and this line repairs that live dead link.
    RedirectPermanent /documents/yachts/featured/2005-manta-42-mkii.pdf                      /documents/yachts/2005-manta-42-mkii-sangaris.pdf
</IfModule>


# ----- 4. Hardening --------------------------------------------------
# No directory listings.
Options -Indexes

# Hide Apache version in error pages.
ServerSignature Off

# Content-based ETag instead of the default (which leaks the inode).
FileETag MTime Size

# Deny common sensitive dotfiles. Does not affect .well-known/
# (directory, needed for SSL cert renewal).
<FilesMatch "^\.(htaccess|htpasswd|env|DS_Store|git.*)$">
    Require all denied
</FilesMatch>

# Safety net: block .md files at the public root. Internal docs
# live in /docs/ (already blocked via docs/.htaccess). This
# catches any accidental drop of a new .md at the top level.
<FilesMatch "\.md$">
    Require all denied
</FilesMatch>
