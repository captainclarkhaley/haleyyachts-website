# ============================================================
# Vendor Documents - private document store lockdown
# ============================================================
# This directory holds SENSITIVE vendor documents (insurance
# certificates, etc.) uploaded through the vendor app. Nothing in
# here may EVER be reachable directly over the web. The ONLY way to
# fetch a document is the authenticated download endpoint
# (vendors/api/doc-download.php), which checks the session, looks up
# the row, and streams the file with readfile().
#
# The files themselves are .gitignored (only this .htaccess + the
# .gitkeep are tracked) so a cPanel deploy pull never clobbers real
# uploads. BACK THIS FOLDER UP separately, like the .sqlite DB - it
# is live data.
#
# Deny everything, for every Apache version.
# ============================================================

# Apache 2.4
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2 fallback
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>

Options -Indexes -ExecCGI

# Belt-and-suspenders: even if the deny above were ever misconfigured,
# never execute anything in this directory as a script.
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8 .pl .py .cgi .asp .aspx
RemoveType .php .phtml .php3 .php4 .php5 .php7 .php8
