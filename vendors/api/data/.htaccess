# ============================================================
# Vendor Database - data directory lockdown
# ============================================================
# This directory holds the live SQLite file (vendors.sqlite) and
# its journal/WAL files. Nothing in here should EVER be reachable
# over the web. This is belt-and-suspenders: the parent /vendors/
# realm already requires a password, and the DB file is .gitignored.
#
# Deny everything, for every Apache version.
# ============================================================

# Apache 2.4
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2 fallback
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>

Options -Indexes
